# Azure SWA Function App — local settings
# Copy to api/local.settings.json for local dev (already in .gitignore)

# Fernet key for encrypting submitter identifiers (same key as agent .env)
SUGGESTION_ENCRYPTION_KEY=

# GitHub PAT with actions:write scope — used to trigger ingest-suggestion workflow
# For production: create a fine-grained PAT at https://github.com/settings/personal-access-tokens
# with "Actions" read+write permission scoped to alexdarbyshire/theautonomouswriter
GITHUB_PAT=

# GitHub repo in owner/name format
GITHUB_REPO=alexdarbyshire/theautonomouswriter

# Google OAuth (configured in Azure SWA portal, not needed locally)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
