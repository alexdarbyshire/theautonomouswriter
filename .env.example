# Required
OPENROUTER_API_KEY=

# Optional: override LLM model (default: anthropic/claude-sonnet-4)
# OPENROUTER_MODEL=anthropic/claude-sonnet-4

# Optional: Tavily research
TAVILY_API_KEY=
ENABLE_RESEARCH=true

# Optional: AI-generated cover images
ENABLE_IMAGES=true

# Optional: Bluesky posting
ENABLE_BLUESKY=true
BLUESKY_HANDLE=
BLUESKY_APP_PASSWORD=

# Optional: Buttondown newsletter
ENABLE_NEWSLETTER=true
BUTTONDOWN_API_KEY=
BUTTONDOWN_USERNAME=autonomouswriter

# Optional: Bluesky reply bot (responds to replies on own posts)
ENABLE_BLUESKY_REPLIES=true

# Optional: newsletter reply bot (responds to subscriber comments, ingests suggestions)
ENABLE_NEWSLETTER_REPLIES=true

# Optional: topic suggestions via web form, GitHub issues, etc.
ENABLE_SUGGESTIONS=true
SUGGESTION_ENCRYPTION_KEY=  # Fernet key for encrypting submitter identifiers (generate with: uv run python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")

# Optional: skip schedule check for local testing
FORCE_POST=true
